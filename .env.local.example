# ─────────────────────────────────────────────────────────────────────
# GOOGLE SHEETS INTEGRATION — copy this file to .env.local and fill in
# ─────────────────────────────────────────────────────────────────────
#
# ONE-TIME SETUP (~5 minutes):
#
# STEP 1  Go to https://console.cloud.google.com/
#         Create a project (or pick an existing one)
#         Search "Google Sheets API" → Enable it
#
# STEP 2  IAM & Admin → Service Accounts → + Create Service Account
#         Give it any name (e.g. "life-audit-sheets")
#         Finish creation → open the service account → Keys tab
#         Add Key → Create new key → JSON → Download
#
# STEP 3  Open your Google Spreadsheet
#         Share → paste the service account email from the JSON file
#         (looks like: name@your-project.iam.gserviceaccount.com)
#         Set role to "Editor" → Send
#
# STEP 4  Fill in the three vars below from the downloaded JSON file
#         GOOGLE_SPREADSHEET_ID is the long ID in your sheet's URL:
#         https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
# ─────────────────────────────────────────────────────────────────────

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-from-the-url
