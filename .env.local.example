# ─────────────────────────────────────────────────────────────────────
# Google Sheets — via Apps Script (no Cloud Console required)
#
# 1. Open your Google Sheet → Extensions → Apps Script
# 2. Paste the contents of google-apps-script.js
# 3. Deploy → New deployment → Web app
#    Execute as: Me  |  Who has access: Anyone
# 4. Copy the Web App URL and paste it below
# 5. For GitHub Pages: add APPS_SCRIPT_URL as a repo Actions secret
# ─────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
